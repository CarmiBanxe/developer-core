{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://banxe.internal/schemas/scenario_registry.schema.json",
  "title": "BANXE Scenario Registry",
  "description": "Validation schema for scenario_registry.yaml — enforces AMLTRIX mapping invariants per ADR-007",
  "type": "object",
  "required": ["amltrix_catalog_version", "scenarios"],
  "properties": {
    "amltrix_catalog_version": {
      "type": "string",
      "description": "Pin of AMLTRIX catalog version this registry was last reviewed against",
      "pattern": "^\\d{4}-Q[1-4]$",
      "examples": ["2025-Q4"]
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Scenario" }
    }
  },

  "definitions": {
    "Scenario": {
      "type": "object",
      "required": ["id", "name", "source", "jurisdiction", "status", "review_cycle", "linked_rules"],
      "properties": {

        "id": {
          "type": "string",
          "pattern": "^SCN-\\d{3,}$",
          "description": "Unique scenario identifier, format SCN-NNN"
        },
        "name": {
          "type": "string",
          "minLength": 5,
          "maxLength": 120
        },
        "description": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": ["amltrix", "hybrid", "internal"],
          "description": "amltrix/hybrid require full AMLTRIX fields; internal allows null with pending_review flag"
        },
        "jurisdiction": {
          "type": "string",
          "enum": ["UK"],
          "description": "Currently UK FCA only. Add new values via ADR when second jurisdiction onboarded (ADR-008 DEFERRED)."
        },
        "status": {
          "type": "string",
          "enum": ["active", "draft", "deprecated"]
        },
        "review_cycle": {
          "type": "string",
          "enum": ["monthly", "quarterly", "annual"]
        },
        "linked_rules": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "At least one rule ID must be linked. Use TBD-* prefix for planned rules."
        },
        "linked_engines": {
          "type": "array",
          "items": { "type": "string" }
        },
        "engines": {
          "type": "array",
          "items": { "$ref": "#/definitions/EngineBinding" },
          "description": "Structured engine bindings (I-8..I-10). May be empty for planned scenarios."
        },
        "expected_decision": {
          "type": "string",
          "enum": ["APPROVE", "HOLD", "REJECT", "SAR", "CONFIRMED", "REFUTED", "UNCERTAIN"]
        },
        "amltrix": {
          "oneOf": [
            { "$ref": "#/definitions/AmltrixMapping" },
            { "type": "null" }
          ],
          "description": "Required non-null for source: amltrix or hybrid. May be null for source: internal."
        },
        "amltrix_pending_review": {
          "type": "boolean",
          "description": "Required for source: internal. true = open AMLTRIX mapping backlog item."
        },
        "policy_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "string"
        }
      },

      "if": {
        "properties": { "source": { "enum": ["amltrix", "hybrid"] } }
      },
      "then": {
        "required": ["amltrix"],
        "properties": {
          "amltrix": {
            "not": { "type": "null" },
            "description": "amltrix block must be non-null for source: amltrix or hybrid"
          }
        }
      },
      "else": {
        "required": ["amltrix_pending_review"],
        "description": "source: internal requires amltrix_pending_review boolean"
      }
    },

    "EngineBinding": {
      "type": "object",
      "required": ["id", "mode", "rule_id", "enabled"],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "tx_monitor",
            "sanctions_check",
            "crypto_aml",
            "compliance_validator",
            "workflow_agent",
            "banxe_aml_orchestrator",
            "case_orchestrator"
          ],
          "description": "Engine identifier from closed enum (I-8)"
        },
        "mode": {
          "type": "string",
          "enum": ["rule", "ml", "hybrid"],
          "description": "Detection mode (I-9)"
        },
        "rule_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Z][A-Z0-9_-]+$",
          "description": "Rule/model identifier; unique within (scenario_id, engine.id) — I-10"
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether this binding is live in production"
        }
      }
    },

    "AmltrixMapping": {
      "type": "object",
      "required": ["tactic_id", "technique_id", "amltrix_version"],
      "properties": {
        "tactic_id": {
          "type": "string",
          "pattern": "^TA-\\d{3,}$",
          "description": "AMLTRIX Tactic ID, format TA-NNN",
          "examples": ["TA-012"]
        },
        "technique_id": {
          "type": "string",
          "pattern": "^T-\\d{3,}$",
          "description": "AMLTRIX Technique ID, format T-NNN",
          "examples": ["T-047"]
        },
        "amltrix_version": {
          "type": "string",
          "pattern": "^\\d{4}-Q[1-4]$",
          "description": "Quarterly AMLTRIX version used for this mapping",
          "examples": ["2025-Q4"]
        },
        "sub_technique_id": {
          "type": "string",
          "pattern": "^T-\\d{3,}\\.\\d{3,}$",
          "description": "Optional AMLTRIX sub-technique, format T-NNN.NNN"
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "mapping_notes": {
          "type": "string"
        }
      }
    }
  }
}
